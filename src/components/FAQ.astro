---
import { faq } from "../content/site";
---

<section id="faq" class="section bg-ink-50">
  <div class="container-prose">
    <div class="max-w-2xl">
      <span class="eyebrow">{faq.eyebrow}</span>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-ink-900">{faq.title}</h2>
    </div>

    <div class="mt-10 grid gap-3 max-w-3xl">
      {faq.items.map((item, i) => (
        <details class="group rounded-xl border border-ink-200 bg-white p-5 open:shadow-sm transition-shadow" name="faq" open={i === 0}>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
            <span class="font-display text-base font-semibold text-ink-900">{item.q}</span>
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-ink-100 text-ink-700 transition-transform group-open:rotate-45">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
                <path d="M12 5v14"/><path d="M5 12h14"/>
              </svg>
            </span>
          </summary>
          <p class="mt-3 text-sm text-ink-600 leading-relaxed">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
