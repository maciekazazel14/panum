---
import Icon from "./Icon.astro";
import { services } from "../content/site";
---

<section id="oferta" class="section">
  <div class="container-prose">
    <div class="max-w-2xl">
      <span class="eyebrow">{services.eyebrow}</span>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-ink-900">{services.title}</h2>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {services.items.map((item) => (
        <article class="card">
          <div class="grid h-11 w-11 place-items-center rounded-lg bg-ink-900 text-white">
            <Icon name={item.icon as any} class="h-5 w-5" />
          </div>
          <h3 class="mt-5 font-display text-lg font-semibold text-ink-900">{item.title}</h3>
          <p class="mt-2 text-ink-600 leading-relaxed">{item.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
