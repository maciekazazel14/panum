---
import { process } from "../content/site";
---

<section id="proces" class="section">
  <div class="container-prose">
    <div class="max-w-2xl">
      <span class="eyebrow">{process.eyebrow}</span>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-ink-900">{process.title}</h2>
    </div>

    <ol class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {process.steps.map((step, i) => (
        <li class="relative card">
          <div class="font-display text-5xl font-bold text-ink-200 leading-none">{String(i + 1).padStart(2, "0")}</div>
          <h3 class="mt-4 font-display text-lg font-semibold text-ink-900">{step.title}</h3>
          <p class="mt-2 text-sm text-ink-600 leading-relaxed">{step.desc}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
