---
import { contact, company } from "../content/site";
import Icon from "./Icon.astro";

// Web3Forms access key — replace with the real key after registering at https://web3forms.com.
// Free tier: 250 mails/month. The key is public-safe by design.
const WEB3FORMS_KEY = "REPLACE_WITH_WEB3FORMS_KEY";
---

<section id="kontakt" class="section">
  <div class="container-prose">
    <div class="max-w-2xl">
      <span class="eyebrow">{contact.eyebrow}</span>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-ink-900">{contact.title}</h2>
      <p class="mt-3 text-ink-600 leading-relaxed">{contact.intro}</p>
    </div>

    <div class="mt-10 grid gap-8 lg:grid-cols-5">
      <form
        id="contact-form"
        class="lg:col-span-3 rounded-2xl border border-ink-200 bg-white p-6 lg:p-8 grid gap-5"
        method="POST"
        action="https://api.web3forms.com/submit"
        enctype="multipart/form-data"
      >
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <input type="hidden" name="subject" value="Nowe zapytanie z panum.pl" />
        <input type="hidden" name="from_name" value="panum.pl" />
        <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

        <div class="grid sm:grid-cols-2 gap-5">
          <label class="grid gap-1.5">
            <span class="text-sm font-medium text-ink-800">Imię i nazwisko / nazwa firmy</span>
            <input type="text" name="name" required class="rounded-lg border border-ink-200 bg-white px-3.5 py-2.5 text-sm text-ink-900 placeholder:text-ink-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" placeholder="np. Acme Sp. z o.o." />
          </label>
          <label class="grid gap-1.5">
            <span class="text-sm font-medium text-ink-800">Email <span class="text-brand-600">*</span></span>
            <input type="email" name="email" required class="rounded-lg border border-ink-200 bg-white px-3.5 py-2.5 text-sm text-ink-900 placeholder:text-ink-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" placeholder="ty@firma.pl" />
          </label>
        </div>

        <label class="grid gap-1.5">
          <span class="text-sm font-medium text-ink-800">Telefon (opcjonalny)</span>
          <input type="tel" name="phone" class="rounded-lg border border-ink-200 bg-white px-3.5 py-2.5 text-sm text-ink-900 placeholder:text-ink-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" placeholder="+48 ___ ___ ___" />
        </label>

        <fieldset class="grid gap-2">
          <legend class="text-sm font-medium text-ink-800">Rodzaj zapytania</legend>
          <div class="grid sm:grid-cols-2 gap-2">
            {contact.inquiryTypes.map((t, i) => (
              <label class="flex items-center gap-3 rounded-lg border border-ink-200 px-3.5 py-2.5 text-sm text-ink-800 hover:border-ink-300 cursor-pointer has-checked:border-brand-500 has-checked:bg-brand-50">
                <input type="radio" name="inquiry_type" value={t.value} checked={i === 0} class="accent-brand-500" />
                {t.label}
              </label>
            ))}
          </div>
        </fieldset>

        <label class="grid gap-1.5">
          <span class="text-sm font-medium text-ink-800">Wiadomość <span class="text-brand-600">*</span></span>
          <textarea name="message" required rows="5" class="rounded-lg border border-ink-200 bg-white px-3.5 py-2.5 text-sm text-ink-900 placeholder:text-ink-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-y" placeholder="Opisz potrzebę, ilość, wymagany materiał lub termin."></textarea>
        </label>

        <label class="grid gap-1.5">
          <span class="text-sm font-medium text-ink-800">Załącznik <span class="text-ink-500 font-normal">(STL, 3MF, STEP, OBJ, ZIP, PDF, JPG, PNG · max 10 MB)</span></span>
          <input
            type="file"
            name="attachment"
            accept=".stl,.3mf,.step,.stp,.obj,.zip,.pdf,.jpg,.jpeg,.png,application/pdf,image/*"
            class="rounded-lg border border-dashed border-ink-300 bg-ink-50 px-3.5 py-2.5 text-sm text-ink-700 file:mr-3 file:rounded-md file:border-0 file:bg-ink-900 file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-white hover:file:bg-ink-800"
          />
        </label>

        <label class="flex items-start gap-3 text-sm text-ink-700">
          <input type="checkbox" name="rodo" required class="mt-1 accent-brand-500" />
          <span>{contact.rodoLabel}</span>
        </label>

        <div class="flex flex-col sm:flex-row sm:items-center gap-4">
          <button type="submit" class="btn btn-primary">
            {contact.submitLabel}
            <Icon name="arrow" class="h-4 w-4" />
          </button>
          <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
        </div>
      </form>

      <aside class="lg:col-span-2 grid gap-4">
        <div class="rounded-2xl border border-ink-200 bg-ink-50 p-6">
          <h3 class="font-display text-lg font-semibold text-ink-900">Kontakt bezpośredni</h3>
          <ul class="mt-4 grid gap-3 text-sm">
            <li class="flex items-center gap-3 text-ink-700">
              <Icon name="mail" class="h-4 w-4 text-ink-500" />
              <a href={`mailto:${company.email}`} class="hover:text-ink-900">{company.email}</a>
            </li>
            <li class="flex items-center gap-3 text-ink-700">
              <Icon name="phone" class="h-4 w-4 text-ink-500" />
              <a href={company.phoneHref} class="hover:text-ink-900">{company.phone}</a>
            </li>
            <li class="flex items-center gap-3 text-ink-700">
              <Icon name="clock" class="h-4 w-4 text-ink-500" />
              {company.hours}
            </li>
          </ul>
        </div>

        <div class="rounded-2xl border border-ink-200 bg-white p-6">
          <h3 class="font-display text-lg font-semibold text-ink-900">Dane do faktury VAT</h3>
          <dl class="mt-4 grid gap-2 text-sm text-ink-700">
            <div><dt class="text-xs uppercase tracking-wide text-ink-500">Nabywca</dt><dd>{company.owner}</dd></div>
            <div><dt class="text-xs uppercase tracking-wide text-ink-500">Adres</dt><dd>{company.addressLine}<br />{company.addressCity}</dd></div>
            <div class={company.regon ? "grid grid-cols-2 gap-2" : ""}>
              <div><dt class="text-xs uppercase tracking-wide text-ink-500">NIP</dt><dd>{company.nip}</dd></div>
              {company.regon && (
                <div><dt class="text-xs uppercase tracking-wide text-ink-500">REGON</dt><dd>{company.regon}</dd></div>
              )}
            </div>
          </dl>
        </div>
      </aside>
    </div>
  </div>
</section>

<script is:inline define:vars={{ successMsg: contact.successMsg, errorMsg: contact.errorMsg }}>
  const form = document.getElementById("contact-form");
  const status = document.getElementById("form-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!status) return;
    status.textContent = "Wysyłam…";
    status.className = "text-sm text-ink-600";

    const data = new FormData(form);
    try {
      const res = await fetch(form.action, { method: "POST", body: data });
      const json = await res.json().catch(() => ({}));
      if (res.ok && json.success !== false) {
        status.textContent = successMsg;
        status.className = "text-sm text-emerald-600 font-medium";
        form.reset();
      } else {
        status.textContent = errorMsg;
        status.className = "text-sm text-red-600 font-medium";
      }
    } catch {
      status.textContent = errorMsg;
      status.className = "text-sm text-red-600 font-medium";
    }
  });
</script>
