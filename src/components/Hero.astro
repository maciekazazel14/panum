---
import { hero } from "../content/site";

// G-code helix path: a single continuous line spirals up forming a vase silhouette.
// Math: (r·cosθ, baseY − height·t + r·sinθ·squash) — isometric projection of a 3D helix.
const turns = 14;
const stepsPerTurn = 56;
const cx = 200;
const baseY = 320;
const totalHeight = 240;
const rxBase = 95;
const ryBase = 28; // isometric squash
// Vase profile: wider base, pinched waist, flared top.
const profile = (t: number) => 0.78 - 0.42 * Math.sin(Math.PI * t) + 0.30 * t;

const points: [number, number][] = [];
for (let i = 0; i <= turns * stepsPerTurn; i++) {
  const t = i / (turns * stepsPerTurn);
  const theta = (i / stepsPerTurn) * 2 * Math.PI;
  const r = profile(t);
  const x = cx + rxBase * r * Math.cos(theta);
  const y = baseY - totalHeight * t + ryBase * r * Math.sin(theta);
  points.push([x, y]);
}

const pathD = points
  .map(([x, y], i) => `${i === 0 ? "M" : "L"} ${x.toFixed(1)} ${y.toFixed(1)}`)
  .join(" ");

let pathLength = 0;
for (let i = 1; i < points.length; i++) {
  const dx = points[i][0] - points[i - 1][0];
  const dy = points[i][1] - points[i - 1][1];
  pathLength += Math.sqrt(dx * dx + dy * dy);
}
pathLength = Math.ceil(pathLength);
---

<section class="relative overflow-hidden">
  <!-- Background grid + gradient (no stock photo) -->
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-ink-50 via-white to-white"></div>
    <div class="absolute inset-0 opacity-[0.35]" style="background-image: linear-gradient(to right, rgba(15,23,42,0.07) 1px, transparent 1px), linear-gradient(to bottom, rgba(15,23,42,0.07) 1px, transparent 1px); background-size: 56px 56px; mask-image: radial-gradient(ellipse at top, rgba(0,0,0,0.6), transparent 70%);"></div>
    <div class="absolute -top-24 -right-24 h-72 w-72 rounded-full bg-brand-500/10 blur-3xl"></div>
  </div>

  <div class="container-prose pt-16 pb-20 lg:pt-24 lg:pb-28 grid gap-12 lg:grid-cols-12 items-center">
    <div class="lg:col-span-7">
      <span class="eyebrow">{hero.eyebrow}</span>
      <h1 class="mt-4 font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight text-ink-900">
        {hero.h1}
      </h1>
      <p class="mt-6 text-lg lg:text-xl text-ink-600 max-w-2xl leading-relaxed">
        {hero.sub}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href={hero.ctaPrimary.href} class="btn btn-primary">
          {hero.ctaPrimary.label}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14" />
            <path d="m13 6 6 6-6 6" />
          </svg>
        </a>
        <a href={hero.ctaSecondary.href} class="btn btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {hero.ctaSecondary.label}
        </a>
      </div>

      <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-3 text-sm font-medium text-ink-700">
        {hero.badges.map((b) => (
          <li class="inline-flex items-center gap-2">
            <span class="grid h-5 w-5 place-items-center rounded-full bg-brand-500/15 text-brand-600">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </span>
            {b}
          </li>
        ))}
      </ul>
    </div>

    <!-- Stylized printer "scene" — intentionally not a stock photo -->
    <div class="lg:col-span-5">
      <div class="relative mx-auto max-w-md aspect-square">
        <!-- Backdrop -->
        <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-ink-900 via-ink-900 to-ink-800 shadow-2xl shadow-ink-900/30 ring-1 ring-ink-900/10 overflow-hidden">
          <!-- Subtle grid texture -->
          <div class="absolute inset-0 opacity-[0.07]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 24px 24px;"></div>
          <!-- Vignette -->
          <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 50%, rgba(249,115,22,0.10), transparent 60%);"></div>
        </div>

        <!-- The G-code helix -->
        <svg
          viewBox="0 0 400 380"
          class="absolute inset-0 w-full h-full"
          aria-hidden="true"
          preserveAspectRatio="xMidYMid meet"
        >
          <defs>
            <linearGradient id="gcodeStroke" x1="0%" y1="100%" x2="0%" y2="0%">
              <stop offset="0%" stop-color="#c2410c" stop-opacity="0.4" />
              <stop offset="35%" stop-color="#f97316" stop-opacity="1" />
              <stop offset="100%" stop-color="#fdba74" stop-opacity="1" />
            </linearGradient>
            <radialGradient id="plateGlow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="rgba(249,115,22,0.35)" />
              <stop offset="100%" stop-color="rgba(249,115,22,0)" />
            </radialGradient>
          </defs>

          <!-- Build plate glow -->
          <ellipse cx={cx} cy={baseY + 6} rx={rxBase * 1.3} ry={ryBase * 0.8} fill="url(#plateGlow)" />
          <!-- Build plate outline -->
          <ellipse cx={cx} cy={baseY + 6} rx={rxBase * 1.05} ry={ryBase * 0.42} fill="none" stroke="rgba(255,255,255,0.18)" stroke-width="1" stroke-dasharray="2 4" />

          <!-- The drawing path -->
          <path
            d={pathD}
            stroke="url(#gcodeStroke)"
            stroke-width="1.6"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="gcode-path"
            style={`--len: ${pathLength};`}
          />
        </svg>

        <!-- Stat badges -->
        <div class="absolute -left-3 top-6 rounded-lg bg-white px-3 py-2 text-xs font-semibold text-ink-900 shadow-lg ring-1 ring-ink-200">
          <div class="text-[10px] uppercase tracking-wide text-ink-500">Dokładność</div>
          <div>0,1 mm</div>
        </div>
        <div class="absolute -right-3 bottom-16 rounded-lg bg-white px-3 py-2 text-xs font-semibold text-ink-900 shadow-lg ring-1 ring-ink-200">
          <div class="text-[10px] uppercase tracking-wide text-ink-500">Warstwa</div>
          <div>0,12 mm</div>
        </div>
        <div class="absolute right-6 top-4 rounded-md bg-brand-500 px-2 py-1 text-[10px] font-semibold uppercase tracking-wide text-white shadow-md">FDM</div>
      </div>
    </div>
  </div>
</section>
