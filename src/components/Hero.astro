---
import { hero } from "../content/site";
---

<section class="relative overflow-hidden">
  <!-- Background grid + gradient (no stock photo) -->
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-ink-50 via-white to-white"></div>
    <div class="absolute inset-0 opacity-[0.35]" style="background-image: linear-gradient(to right, rgba(15,23,42,0.07) 1px, transparent 1px), linear-gradient(to bottom, rgba(15,23,42,0.07) 1px, transparent 1px); background-size: 56px 56px; mask-image: radial-gradient(ellipse at top, rgba(0,0,0,0.6), transparent 70%);"></div>
    <div class="absolute -top-24 -right-24 h-72 w-72 rounded-full bg-brand-500/10 blur-3xl"></div>
  </div>

  <div class="container-prose pt-16 pb-20 lg:pt-24 lg:pb-28 grid gap-12 lg:grid-cols-12 items-center">
    <div class="lg:col-span-7">
      <span class="eyebrow">{hero.eyebrow}</span>
      <h1 class="mt-4 font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight text-ink-900">
        {hero.h1}
      </h1>
      <p class="mt-6 text-lg lg:text-xl text-ink-600 max-w-2xl leading-relaxed">
        {hero.sub}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href={hero.ctaPrimary.href} class="btn btn-primary">
          {hero.ctaPrimary.label}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14" />
            <path d="m13 6 6 6-6 6" />
          </svg>
        </a>
        <a href={hero.ctaSecondary.href} class="btn btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {hero.ctaSecondary.label}
        </a>
      </div>

      <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-3 text-sm font-medium text-ink-700">
        {hero.badges.map((b) => (
          <li class="inline-flex items-center gap-2">
            <span class="grid h-5 w-5 place-items-center rounded-full bg-brand-500/15 text-brand-600">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </span>
            {b}
          </li>
        ))}
      </ul>
    </div>

    <!-- Stylized printer "scene" — intentionally not a stock photo -->
    <div class="lg:col-span-5">
      <div class="relative mx-auto max-w-md aspect-square">
        <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-ink-900 to-ink-800 shadow-2xl shadow-ink-900/20 ring-1 ring-ink-900/10"></div>

        <!-- Inner glow -->
        <div class="absolute inset-3 rounded-2xl bg-gradient-to-b from-ink-800/60 to-ink-900/0 ring-1 ring-white/5"></div>

        <!-- Build plate -->
        <div class="absolute inset-x-8 bottom-10 h-2 rounded-sm bg-ink-200/90"></div>

        <!-- Printed object (layered) -->
        <div class="absolute left-1/2 -translate-x-1/2 bottom-12 w-32 h-28">
          <div class="absolute inset-x-0 bottom-0 h-3 bg-gradient-to-t from-brand-700 to-brand-500 rounded-sm"></div>
          <div class="absolute inset-x-2 bottom-3 h-3 bg-gradient-to-t from-brand-700 to-brand-500 rounded-sm opacity-95"></div>
          <div class="absolute inset-x-4 bottom-6 h-3 bg-gradient-to-t from-brand-700 to-brand-500 rounded-sm opacity-90"></div>
          <div class="absolute inset-x-6 bottom-9 h-3 bg-gradient-to-t from-brand-700 to-brand-500 rounded-sm opacity-85"></div>
          <div class="absolute inset-x-8 bottom-12 h-3 bg-gradient-to-t from-brand-700 to-brand-500 rounded-sm opacity-80"></div>
          <div class="absolute inset-x-10 bottom-15 h-3 bg-gradient-to-t from-brand-700 to-brand-500 rounded-sm opacity-75" style="bottom: 3.75rem"></div>
        </div>

        <!-- Print head -->
        <div class="absolute top-10 left-1/2 -translate-x-1/2 flex flex-col items-center">
          <div class="h-1 w-44 bg-ink-700 rounded-full"></div>
          <div class="mt-1 h-8 w-10 rounded-md bg-ink-200 ring-1 ring-white/10 shadow-md flex items-end justify-center">
            <div class="h-2 w-2 rounded-b-full bg-brand-500 animate-pulse"></div>
          </div>
        </div>

        <!-- Stat badges -->
        <div class="absolute -left-3 top-6 rounded-lg bg-white px-3 py-2 text-xs font-semibold text-ink-900 shadow-lg ring-1 ring-ink-200">
          <div class="text-[10px] uppercase tracking-wide text-ink-500">Dokładność</div>
          <div>0,1 mm</div>
        </div>
        <div class="absolute -right-3 bottom-16 rounded-lg bg-white px-3 py-2 text-xs font-semibold text-ink-900 shadow-lg ring-1 ring-ink-200">
          <div class="text-[10px] uppercase tracking-wide text-ink-500">Obszar</div>
          <div>256³ mm</div>
        </div>
        <div class="absolute right-6 top-4 rounded-md bg-brand-500 px-2 py-1 text-[10px] font-semibold uppercase tracking-wide text-white shadow-md">P1S</div>
      </div>
    </div>
  </div>
</section>
