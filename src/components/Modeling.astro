---
import { modeling } from "../content/site";
---

<section class="section">
  <div class="container-prose">
    <div class="rounded-2xl bg-ink-900 text-white p-8 lg:p-14 grid gap-8 lg:grid-cols-2 items-center overflow-hidden relative">
      <div aria-hidden="true" class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-brand-500/30 blur-3xl"></div>

      <div class="relative">
        <span class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-brand-300">{modeling.eyebrow}</span>
        <h2 class="mt-3 font-display text-3xl lg:text-4xl font-bold tracking-tight">{modeling.title}</h2>
        <p class="mt-4 text-ink-200 leading-relaxed max-w-xl">{modeling.body}</p>
        <a href={modeling.cta.href} class="btn btn-primary mt-7">
          {modeling.cta.label}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14" /><path d="m13 6 6 6-6 6" />
          </svg>
        </a>
      </div>

      <div class="relative grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-ink-800 ring-1 ring-white/10 p-5">
          <div class="text-xs font-semibold uppercase tracking-wide text-brand-300">Modelowanie organiczne</div>
          <p class="mt-2 text-sm text-ink-200">Figurki, rzeźby, formy bionic — kształty trudne do uchwycenia w CAD.</p>
        </div>
        <div class="rounded-xl bg-ink-800 ring-1 ring-white/10 p-5">
          <div class="text-xs font-semibold uppercase tracking-wide text-brand-300">CAD techniczny</div>
          <p class="mt-2 text-sm text-ink-200">Precyzyjne obudowy, mocowania, części wymiarowe — pasują na pierwszy raz.</p>
        </div>
        <div class="rounded-xl bg-ink-800 ring-1 ring-white/10 p-5 col-span-2">
          <div class="text-xs font-semibold uppercase tracking-wide text-brand-300">Stawka</div>
          <p class="mt-2 text-sm text-ink-200">od <span class="font-semibold text-white">80&nbsp;PLN&nbsp;netto/h</span> · wycena projektu po krótkim briefie</p>
        </div>
      </div>
    </div>
  </div>
</section>
