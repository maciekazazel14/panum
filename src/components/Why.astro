---
import Icon from "./Icon.astro";
import { why } from "../content/site";
---

<section class="section bg-ink-50">
  <div class="container-prose">
    <div class="max-w-2xl">
      <span class="eyebrow">{why.eyebrow}</span>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-ink-900">{why.title}</h2>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {why.items.map((item) => (
        <article class="card">
          <div class="grid h-10 w-10 place-items-center rounded-lg bg-brand-500/10 text-brand-600">
            <Icon name={item.icon as any} class="h-5 w-5" />
          </div>
          <h3 class="mt-4 font-display text-base font-semibold text-ink-900">{item.title}</h3>
          <p class="mt-2 text-sm text-ink-600 leading-relaxed">{item.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
