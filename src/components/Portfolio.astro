---
import { portfolio } from "../content/site";

// Decorative SVG patterns as portfolio placeholders. Owner will swap with photos.
const patterns = [
  { from: "#1e293b", to: "#0f172a", accent: "#f97316" },
  { from: "#0f172a", to: "#334155", accent: "#fb923c" },
  { from: "#334155", to: "#0f172a", accent: "#fdba74" },
  { from: "#0f172a", to: "#1e293b", accent: "#f97316" },
  { from: "#1e293b", to: "#0f172a", accent: "#fb923c" },
  { from: "#0f172a", to: "#334155", accent: "#fdba74" },
];
---

<section id="portfolio" class="section">
  <div class="container-prose">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 max-w-3xl">
      <div>
        <span class="eyebrow">{portfolio.eyebrow}</span>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-ink-900">{portfolio.title}</h2>
      </div>
      <p class="text-sm text-ink-500 max-w-md">{portfolio.note}</p>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {portfolio.items.map((item, i) => {
        const p = patterns[i % patterns.length];
        return (
          <figure class="group overflow-hidden rounded-xl border border-ink-200 bg-white">
            <div class="aspect-[4/3] relative overflow-hidden">
              <div class="absolute inset-0" style={`background: linear-gradient(135deg, ${p.from}, ${p.to});`}></div>
              <svg class="absolute inset-0 w-full h-full opacity-90" viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
                <defs>
                  <pattern id={`grid-${i}`} width="20" height="20" patternUnits="userSpaceOnUse">
                    <path d="M 20 0 L 0 0 0 20" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
                  </pattern>
                </defs>
                <rect width="400" height="300" fill={`url(#grid-${i})`} />
                <g transform="translate(200,170)" opacity="0.95">
                  <polygon points="-50,30 50,30 60,-10 0,-40 -60,-10" fill={p.accent} opacity="0.85"/>
                  <polygon points="-50,30 50,30 60,-10 0,-40 -60,-10" fill="none" stroke="white" stroke-opacity="0.25" stroke-width="1"/>
                  <line x1="-60" y1="-10" x2="60" y2="-10" stroke="white" stroke-opacity="0.15"/>
                  <line x1="0" y1="-40" x2="0" y2="30" stroke="white" stroke-opacity="0.15"/>
                </g>
                <text x="20" y="280" fill="white" fill-opacity="0.45" font-family="monospace" font-size="11">PANUM // {String(i + 1).padStart(2, "0")}</text>
              </svg>
            </div>
            <figcaption class="p-4">
              <div class="font-display text-base font-semibold text-ink-900">{item.title}</div>
              <div class="text-xs text-ink-500 mt-0.5">{item.meta}</div>
            </figcaption>
          </figure>
        );
      })}
    </div>
  </div>
</section>
